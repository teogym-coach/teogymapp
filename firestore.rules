rules_version = '2';

// ═══════════════════════════════════════════════════════════════
//  TEO GYM — Firestore 보안 규칙 v8
//
//  회원앱 원칙:
//    - 대표자: members/{memberId}.trainerUid == request.auth.uid 인 데이터 접근
//    - 회원 본인: members/{memberId}.memberUid == request.auth.uid
//               이면서 status == "active" (진행중) 인 회원만 접근 허용
//    - 휴식중(paused) / 종료(ended) / 상태값 없음 / 알 수 없는 상태 → 회원 self-access 차단
//    - 수업일지는 회원 본인에게 isPublished == true 일 때만 공개
// ═══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function memberDoc(memberId) {
      return get(/databases/$(database)/documents/members/$(memberId)).data;
    }

    function isTrainerData(data) {
      return isSignedIn() && data.trainerUid == uid();
    }

    function isMemberUidData(data) {
      return isSignedIn() && data.memberUid == uid();
    }

    // 진행중 상태 확인: active 계열 값만 허용, 그 외 모두 차단
    function isMemberStatusActive(data) {
      return data.status == "active"
          || data.memberStatus == "active"
          || data.status == "pt"
          || data.memberStatus == "pt"
          || data.status == "pt_active"
          || data.memberStatus == "pt_active"
          || data.status == "in_progress"
          || data.memberStatus == "in_progress"
          || data.status == "진행중"
          || data.memberStatus == "진행중"
          || data.status == "진행"
          || data.memberStatus == "진행"
          || data.status == "pt진행"
          || data.memberStatus == "pt진행"
          || data.status == "pt 진행중"
          || data.memberStatus == "pt 진행중";
    }

    function canReadMemberData(data) {
      return isTrainerData(data)
          || (isMemberUidData(data) && isMemberStatusActive(data));
    }

    function isTrainerOfMember(memberId) {
      return isTrainerData(memberDoc(memberId));
    }

    // uid 일치만 확인 (상태 무관) — 내부 헬퍼로만 사용
    function isMemberSelf(memberId) {
      let m = memberDoc(memberId);
      return isMemberUidData(m);
    }

    // uid 일치 + 진행중 상태 확인 — 회원 self-access 게이트
    function isMemberSelfActive(memberId) {
      let m = memberDoc(memberId);
      return isMemberUidData(m) && isMemberStatusActive(m);
    }

    // 관리자 OR 진행중 회원 본인
    function canAccessMember(memberId) {
      return isTrainerOfMember(memberId) || isMemberSelfActive(memberId);
    }

    function isPublishedData(data) {
      return (data.status == "published" || data.published == true || data.isPublished == true)
        && data.visible != false && data.visibility != "hidden";
    }

    function memberProfileUpdateKeysAllowed() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "workoutFrequency", "weeklyWorkoutCount", "height", "startWeight", "currentWeight", "targetWeight", "targetWeightKg", "goal", "goalPeriod", "goalPeriodType", "goalDeadline", "targetDate", "customGoalDate", "memberAppLastLoginAt", "updatedAt",
        "birthYear", "birthMonth", "birthDay", "birthYearMonth", "birthSource",
        "fcmToken", "fcmTokenUpdatedAt",
        "memberLastInputAt"
      ]);
    }

    function memberOnboardingProfileKeysAllowed() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "gender", "birthYear", "birthMonth", "birthDay", "birthYearMonth", "jobType", "averageWorkoutTime", "averageSteps", "focusAreas",
        "completed", "completedAt", "weightHistoryMode", "calorieHistoryMode", "weightHistoryModeStartedAt", "calorieHistoryModeStartedAt",
        "weightHistoryModeTransferredAt", "calorieHistoryModeTransferredAt",
        "weeklyWorkoutCount", "workoutFrequency", "goal", "heightCm", "height",
        "startingWeightKg", "startWeight", "currentWeightKg", "currentWeight", "weight", "targetWeight", "targetWeightKg",
        "targetPeriod", "targetPeriodCustom", "goalPeriod", "goalPeriodType", "goalDeadline", "targetDate", "customGoalDate", "updatedAt"
      ]);
    }

    function memberOnboardingCreateKeysAllowed() {
      return request.resource.data.keys().hasOnly([
        "gender", "birthYear", "birthMonth", "birthDay", "birthYearMonth", "jobType", "averageWorkoutTime", "averageSteps", "focusAreas",
        "completed", "completedAt", "weightHistoryMode", "calorieHistoryMode", "weightHistoryModeStartedAt", "calorieHistoryModeStartedAt",
        "weightHistoryModeTransferredAt", "calorieHistoryModeTransferredAt",
        "weeklyWorkoutCount", "workoutFrequency", "goal", "heightCm", "height",
        "startingWeightKg", "startWeight", "currentWeightKg", "currentWeight", "weight", "targetWeight", "targetWeightKg",
        "targetPeriod", "targetPeriodCustom", "goalPeriod", "goalPeriodType", "goalDeadline", "targetDate", "customGoalDate", "updatedAt"
      ]);
    }

    function bodyCheckProfileUpdateKeysAllowed() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "records", "goal", "inbody", "updatedAt", "currentWeight", "weight", "targetWeight", "targetWeightKg"
      ]);
    }

    function bodyCheckProfileCreateKeysAllowed() {
      return request.resource.data.keys().hasOnly([
        "records", "goal", "inbody", "updatedAt", "currentWeight", "weight", "targetWeight", "targetWeightKg"
      ]);
    }

    function isTargetMemberSelf(targetMemberId) {
      return exists(/databases/$(database)/documents/members/$(targetMemberId))
        && get(/databases/$(database)/documents/members/$(targetMemberId)).data.memberUid == uid();
    }

    match /members/{memberId} {

      // get/list: 관리자(trainerUid) + 진행중 회원 본인(memberUid + status==active)
      allow get, list: if canReadMemberData(resource.data);

      // 생성: 반드시 내 uid로 trainerUid 설정
      allow create: if isSignedIn()
                    && request.resource.data.trainerUid == uid();

      // 수정: 관리자 전체 관리 / 진행중 회원 본인은 허용된 프로필 필드만
      allow update: if isSignedIn()
                    && (
                      (resource.data.trainerUid == uid()
                        && request.resource.data.trainerUid == uid())
                      || (resource.data.memberUid == uid()
                          && isMemberStatusActive(resource.data)
                          && request.auth != null
                          && memberProfileUpdateKeysAllowed())
                    );

      allow delete: if isSignedIn()
                    && resource.data.trainerUid == uid();

      match /sessions/{sessionId} {
        allow read: if isTrainerOfMember(memberId)
                    || (isMemberSelfActive(memberId) && resource.data.isPublished == true);
        allow create, delete: if isTrainerOfMember(memberId);
        allow update: if isTrainerOfMember(memberId)
                      || (isMemberSelfActive(memberId)
                          && resource.data.isPublished == true
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["sorenessReport", "sorenessUpdatedAt"]));

        match /memberFeedback/{feedbackUid} {
          allow read: if isTrainerOfMember(memberId)
                      || (isMemberSelfActive(memberId) && feedbackUid == uid());
          allow create, update: if isTrainerOfMember(memberId)
                                || (isMemberSelfActive(memberId)
                                    && feedbackUid == uid()
                                    && request.resource.data.source == "memberApp"
                                    && request.resource.data.keys().hasOnly(["sorenessLevel", "sorenessBodyPart", "sorenessBodyParts", "rpe", "memo", "createdAt", "updatedAt", "source"]));
          allow delete: if isTrainerOfMember(memberId);
        }
      }

      match /memberCheckins/{checkinId} {
        allow read, create, update: if canAccessMember(memberId);
        allow delete: if canAccessMember(memberId);
      }

      match /memberMessages/{messageId} {
        allow read, create, update: if canAccessMember(memberId);
        allow delete: if isTrainerOfMember(memberId);
      }

      match /attendance/{dateId} {
        allow read: if isTrainerOfMember(memberId) || isMemberSelfActive(memberId);
        allow create: if isMemberSelfActive(memberId)
                      && request.resource.data.keys().hasOnly(["date", "createdAt", "updatedAt", "source"])
                      && request.resource.data.date == dateId;
        allow update: if false;
        allow delete: if isTrainerOfMember(memberId);
      }

      match /readSessions/{sessionId} {
        allow read: if isTrainerOfMember(memberId) || isMemberSelfActive(memberId);
        allow create, update: if isMemberSelfActive(memberId)
                              && request.resource.data.keys().hasOnly(["readAt"]);
        allow delete: if isTrainerOfMember(memberId);
      }

      match /noticeReads/{noticeId} {
        allow read: if canAccessMember(memberId);
        allow create, update: if isMemberSelfActive(memberId)
          && request.resource.data.noticeId == noticeId
          && request.resource.data.keys().hasOnly(["noticeId", "readAt"]);
        allow delete: if isTrainerOfMember(memberId);
      }

      match /bodyCheck/{docId} {
        allow read: if canAccessMember(memberId);
        allow create: if isTrainerOfMember(memberId)
                      || (isMemberSelfActive(memberId)
                          && docId == "main"
                          && bodyCheckProfileCreateKeysAllowed());
        allow update: if isTrainerOfMember(memberId)
                      || (isMemberSelfActive(memberId)
                          && docId == "main"
                          && bodyCheckProfileUpdateKeysAllowed());
        allow delete: if isTrainerOfMember(memberId);
      }

      match /assessments/{assessmentId} {
        allow read, write: if isTrainerOfMember(memberId);
      }

      match /nutrition/{docId} {
        allow read: if canAccessMember(memberId);
        allow write: if canAccessMember(memberId);
      }

      match /routineRecommendations/{recommendationId} {
        allow read: if isTrainerOfMember(memberId)
                    || (isMemberSelfActive(memberId) && isPublishedData(resource.data));
        allow create, update, delete: if isTrainerOfMember(memberId);
      }

      match /dailyConditioning/{conditioningId} {
        allow read: if isTrainerOfMember(memberId)
                    || (isMemberSelfActive(memberId) && isPublishedData(resource.data));
        allow create, update, delete: if isTrainerOfMember(memberId);
      }

      match /memberOnboarding/{docId} {
        allow read: if canAccessMember(memberId);
        allow create: if isTrainerOfMember(memberId)
                      || (isMemberSelfActive(memberId)
                          && docId == "main"
                          && memberOnboardingCreateKeysAllowed());
        allow update: if isTrainerOfMember(memberId)
                      || (isMemberSelfActive(memberId)
                          && docId == "main"
                          && memberOnboardingProfileKeysAllowed());
        allow delete: if isTrainerOfMember(memberId);
      }

      match /{subCollection}/{docId} {
        allow read, write: if isTrainerOfMember(memberId);
      }
    }

    match /dailyConditioning/{conditioningId} {
      allow read: if isSignedIn() && isPublishedData(resource.data);
      allow create, update: if isSignedIn() && request.resource.data.trainerUid == uid();
      allow delete: if isSignedIn() && resource.data.trainerUid == uid();
    }

    match /notices/{noticeId} {
      allow read: if isSignedIn()
        && (resource.data.trainerUid == uid()
          || (resource.data.isPublished == true
            && (resource.data.targetType == "all"
              || (resource.data.targetType == "member"
                && isTargetMemberSelf(resource.data.targetMemberId)))));
      allow create: if isSignedIn() && request.resource.data.trainerUid == uid() && request.resource.data.createdBy == uid();
      allow update: if isSignedIn() && resource.data.trainerUid == uid() && request.resource.data.trainerUid == uid();
      allow delete: if isSignedIn() && resource.data.trainerUid == uid();
    }

    match /pairSessions/{pairSessionId} {
      allow read: if isSignedIn() && resource.data.trainerUid == uid();
      allow create: if isSignedIn() && request.resource.data.trainerUid == uid();
      allow update: if isSignedIn() && resource.data.trainerUid == uid();
      allow delete: if isSignedIn() && resource.data.trainerUid == uid();
    }
  }
}
