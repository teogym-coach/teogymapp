# TEO GYM — 환경변수 예시
# 이 파일을 .env.local 로 복사하고 실제 값을 채워주세요
# .env.local 은 .gitignore 에 포함되어 있으므로 절대 커밋되지 않습니다

# ── Firebase (현재 firebase-config.js 에 하드코딩됨 — 추후 환경변수로 이전 권장) ──
# REACT_APP_FIREBASE_API_KEY=
# REACT_APP_FIREBASE_AUTH_DOMAIN=
# REACT_APP_FIREBASE_PROJECT_ID=
# REACT_APP_FIREBASE_STORAGE_BUCKET=
# REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
# REACT_APP_FIREBASE_APP_ID=

# ── Sentry 오류 모니터링 (선택) ──
# Sentry.io → 프로젝트 생성 → Settings → Client Keys (DSN) 에서 발급
# 값이 없으면 Sentry는 완전히 비활성화됩니다 — 앱 동작에 영향 없음
REACT_APP_SENTRY_DSN=

# ── 앱 버전 (선택, Sentry release 태깅에 사용) ──
REACT_APP_VERSION=1.0.0
