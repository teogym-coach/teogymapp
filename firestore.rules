rules_version = '2';

// ═══════════════════════════════════════════════════════════════
//  TEO GYM — Firestore 보안 규칙 v6
//
//  회원앱 원칙:
//    - 대표자: members/{memberId}.trainerUid == request.auth.uid 인 데이터 접근
//    - 회원 본인: members/{memberId}.memberUid == request.auth.uid 인 자기 문서 접근
//    - 회원앱은 members where memberUid == request.auth.uid 쿼리로 자기 문서 조회
//    - 수업일지는 회원 본인에게 isPublished == true 일 때만 공개
// ═══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function memberDoc(memberId) {
      return get(/databases/$(database)/documents/members/$(memberId)).data;
    }

    function isTrainerData(data) {
      return isSignedIn() && data.trainerUid == uid();
    }

    function isMemberUidData(data) {
      return isSignedIn() && data.memberUid == uid();
    }

    function canReadMemberData(data) {
      return isTrainerData(data) || isMemberUidData(data);
    }

    function isTrainerOfMember(memberId) {
      return isTrainerData(memberDoc(memberId));
    }

    function isMemberSelf(memberId) {
      let m = memberDoc(memberId);
      return isMemberUidData(m);
    }

    function canAccessMember(memberId) {
      return isTrainerOfMember(memberId) || isMemberSelf(memberId);
    }

    function isPublishedData(data) {
      return (data.status == "published" || data.published == true || data.isPublished == true)
        && data.visible != false && data.visibility != "hidden";
    }

    function memberProfileUpdateKeysAllowed() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "workoutFrequency", "height", "startWeight", "currentWeight", "targetWeightKg", "memberAppLastLoginAt", "updatedAt"
      ]);
    }

    function memberOnboardingProfileKeysAllowed() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "gender", "birthYear", "jobType", "averageWorkoutTime", "averageSteps", "focusAreas",
        "completedAt", "weightHistoryMode", "calorieHistoryMode", "weightHistoryModeStartedAt", "calorieHistoryModeStartedAt",
        "weightHistoryModeTransferredAt", "calorieHistoryModeTransferredAt",
        "weeklyWorkoutCount", "workoutFrequency", "goal", "heightCm", "height",
        "startingWeightKg", "startWeight", "currentWeightKg", "currentWeight", "weight", "targetWeightKg", "updatedAt"
      ]);
    }

    function memberOnboardingCreateKeysAllowed() {
      return request.resource.data.keys().hasOnly([
        "gender", "birthYear", "jobType", "averageWorkoutTime", "averageSteps", "focusAreas",
        "completedAt", "weightHistoryMode", "calorieHistoryMode", "weightHistoryModeStartedAt", "calorieHistoryModeStartedAt",
        "weightHistoryModeTransferredAt", "calorieHistoryModeTransferredAt",
        "weeklyWorkoutCount", "workoutFrequency", "goal", "heightCm", "height",
        "startingWeightKg", "startWeight", "currentWeightKg", "currentWeight", "weight", "targetWeightKg", "updatedAt"
      ]);
    }

    function bodyCheckProfileUpdateKeysAllowed() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "records", "updatedAt", "currentWeight"
      ]);
    }

    function bodyCheckProfileCreateKeysAllowed() {
      return request.resource.data.keys().hasOnly([
        "records", "updatedAt", "currentWeight"
      ]);
    }

    match /members/{memberId} {

      // get/list: 대표자 trainerUid 쿼리와 회원 본인 memberUid 쿼리 허용.
      // 회원앱은 Cloud Functions 없이 members where memberUid == auth.uid 쿼리만 사용합니다.
      allow get, list: if canReadMemberData(resource.data);

      // 생성: 반드시 내 uid로 trainerUid 설정
      allow create: if isSignedIn()
                    && request.resource.data.trainerUid == uid();

      // 수정: 대표자는 전체 관리 가능하며, 회원 본인은 프로필 보정 필드만 수정 가능
      allow update: if isSignedIn()
                    && (
                      (resource.data.trainerUid == uid()
                        && request.resource.data.trainerUid == uid())
                      || (resource.data.memberUid == uid()
                        && request.auth != null
                        && memberProfileUpdateKeysAllowed())
                    );

      allow delete: if isSignedIn()
                    && resource.data.trainerUid == uid();

      match /sessions/{sessionId} {
        allow read: if isTrainerOfMember(memberId)
                    || (isMemberSelf(memberId) && resource.data.isPublished == true);
        allow create, delete: if isTrainerOfMember(memberId);
        allow update: if isTrainerOfMember(memberId)
                      || (isMemberSelf(memberId)
                          && resource.data.isPublished == true
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["sorenessReport", "sorenessUpdatedAt"]));

        match /memberFeedback/{feedbackUid} {
          allow read: if isTrainerOfMember(memberId)
                      || (isMemberSelf(memberId) && feedbackUid == uid());
          allow create, update: if isTrainerOfMember(memberId)
                                || (isMemberSelf(memberId)
                                    && feedbackUid == uid()
                                    && request.resource.data.source == "memberApp"
                                    && request.resource.data.keys().hasOnly(["sorenessLevel", "sorenessBodyPart", "sorenessBodyParts", "rpe", "memo", "createdAt", "updatedAt", "source"]));
          allow delete: if isTrainerOfMember(memberId);
        }
      }

      match /memberCheckins/{checkinId} {
        allow read, create, update: if canAccessMember(memberId);
        allow delete: if canAccessMember(memberId);
      }

      match /memberMessages/{messageId} {
        allow read, create, update: if canAccessMember(memberId);
        allow delete: if isTrainerOfMember(memberId);
      }

      match /bodyCheck/{docId} {
        allow read: if canAccessMember(memberId);
        allow create: if isTrainerOfMember(memberId)
                      || (isMemberSelf(memberId)
                          && docId == "main"
                          && bodyCheckProfileCreateKeysAllowed());
        allow update: if isTrainerOfMember(memberId)
                      || (isMemberSelf(memberId)
                          && docId == "main"
                          && bodyCheckProfileUpdateKeysAllowed());
        allow delete: if isTrainerOfMember(memberId);
      }

      match /assessments/{assessmentId} {
        allow read, write: if isTrainerOfMember(memberId);
      }

      match /nutrition/{docId} {
        allow read: if canAccessMember(memberId);
        allow write: if canAccessMember(memberId);
      }

      match /routineRecommendations/{recommendationId} {
        allow read: if isTrainerOfMember(memberId)
                    || (isMemberSelf(memberId) && isPublishedData(resource.data));
        allow create, update, delete: if isTrainerOfMember(memberId);
      }

      match /dailyConditioning/{conditioningId} {
        allow read: if isTrainerOfMember(memberId)
                    || (isMemberSelf(memberId) && isPublishedData(resource.data));
        allow create, update, delete: if isTrainerOfMember(memberId);
      }

      match /memberOnboarding/{docId} {
        allow read: if canAccessMember(memberId);
        allow create: if isTrainerOfMember(memberId)
                      || (isMemberSelf(memberId)
                          && docId == "main"
                          && memberOnboardingCreateKeysAllowed());
        allow update: if isTrainerOfMember(memberId)
                      || (isMemberSelf(memberId)
                          && docId == "main"
                          && memberOnboardingProfileKeysAllowed());
        allow delete: if isTrainerOfMember(memberId);
      }

      match /{subCollection}/{docId} {
        allow read, write: if isTrainerOfMember(memberId);
      }
    }

    match /dailyConditioning/{conditioningId} {
      allow read: if isSignedIn() && isPublishedData(resource.data);
      allow create, update: if isSignedIn() && request.resource.data.trainerUid == uid();
      allow delete: if isSignedIn() && resource.data.trainerUid == uid();
    }
  }
}
